{
  "files.associations": {
    ".fantomasignore": "ignore",
    "iostream": "cpp",
    "ostream": "cpp",
    "string": "cpp",
    "iosfwd": "cpp",
    "fstream": "cpp",
    "valarray": "cpp",
    "chrono": "cpp",
    "functional": "cpp",
    "vector": "cpp",
    "atomic": "cpp",
    "cwchar": "cpp",
    "exception": "cpp",
    "initializer_list": "cpp",
    "istream": "cpp",
    "new": "cpp",
    "stdexcept": "cpp",
    "streambuf": "cpp",
    "tuple": "cpp",
    "type_traits": "cpp",
    "utility": "cpp"
  },
  "files.exclude": {
    "**/!(*.*)": true,
    "**/*.out": true
  },
  "launch": {
    "configurations": [],
    "compounds": []
