{
  "files.associations": {
    ".fantomasignore": "ignore",
    "iostream": "cpp",
    "ostream": "cpp",
    "string": "cpp",
    "iosfwd": "cpp",
    "fstream": "cpp",
    "valarray": "cpp",
    "chrono": "cpp",
    "functional": "cpp",
    "vector": "cpp"
  },
  "files.exclude": {
    "**/!(*.*)": true,
    "**/*.out": true
  },
  "launch": {
    "configurations": [],
    "compounds": []
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  }
}
